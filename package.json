{
  "name": "vigil",
  "version": "1.1.2",
  "description": "A dashboard application that allows users to define custom endpoints for widgets such as server health &amp; statistics. Users also have access to collection of custom widgets that create a complete user experience.",
  "main": "server/app.ts",
  "scripts": {
    "predev": "kill-port 3000",
    "dev": "concurrently --kill-others-on-fail \"webpack watch\" \"npx nodemon --signal SIGTERM --watch server --exec tsx server/app.ts\"",
    "build": "webpack",
    "start": "node dist/app.js",
    "heroku-postbuild": "tsc && webpack",
    "pretest": "eslint ./server --fix",
    "test": "echo \"All tests completed\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CarterIrish/Vigil.git"
  },
  "keywords": [],
  "author": "Carter Irish",
  "license": "MIT",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/CarterIrish/Vigil/issues"
  },
  "homepage": "https://github.com/CarterIrish/Vigil#readme",
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@babel/preset-env": "^8.0.2",
    "@babel/preset-react": "^8.0.1",
    "@eslint/js": "^10.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.19.0",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/serve-favicon": "^2.5.7",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.58.0",
    "babel-loader": "^10.1.1",
    "concurrently": "^10.0.3",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "kill-port": "^2.0.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.0.3"
  },
  "dependencies": {
    "@dnd-kit/react": "^0.4.0",
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "connect-redis": "^9.0.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-handlebars": "^9.0.1",
    "express-session": "^1.19.0",
    "helmet": "^8.1.0",
    "mongoose": "^9.6.1",
    "redis": "^5.12.1",
    "serve-favicon": "^2.5.1",
    "underscore": "^1.13.8"
  }
}
