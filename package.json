    "url": "https://github.com/CarterIrish/Vigil/issues"
  },
  "homepage": "https://github.com/CarterIrish/Vigil#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/node": "^25.5.2",
    "@types/serve-favicon": "^2.5.7",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^10.1.0",
